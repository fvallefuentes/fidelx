# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# netlify local build cache
/.netlify/

# logs locaux
*.log

# production
/build

# misc
.DS_Store
# Clés privées et certificats binaires — jamais en git
*.p12
# Les .pem dans /certificates/ sont committés (repo privé, nécessaire pour Netlify)
# Les .pem ailleurs restent exclus
*.pem
!/certificates/*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.production.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
