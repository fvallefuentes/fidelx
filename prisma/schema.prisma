generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================
// AUTHENTIFICATION (NextAuth)
// =============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Code OTP pour la vérification email à l'inscription commerçant
// (séparé de VerificationToken qui est réservé à NextAuth).
model EmailVerificationCode {
  id         String    @id @default(cuid())
  email      String
  codeHash   String    // hash bcrypt du code 6 chiffres
  expiresAt  DateTime
  usedAt     DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
}

/// Code 2FA par email envoyé à chaque login d'un user qui a email2faEnabled=true.
/// Distinct de EmailVerificationCode (qui sert à la vérification email à l'inscription)
/// pour avoir un TTL plus court (10 min vs 24h) et un suivi anti-bruteforce séparé.
///
/// Sécurité :
///  - Code 6 chiffres (= 1M combos, suffisant pour TTL 10min + rate limit 5 tries)
///  - Stocké en hash sha256, jamais en clair
///  - Usage unique (usedAt)
///  - Max 5 tentatives par code (sinon = invalidé pour empêcher brute force)
model EmailLoginCode {
  id         String    @id @default(cuid())
  userId     String
  codeHash   String    // sha256 hex du code 6 chiffres
  expiresAt  DateTime
  usedAt     DateTime?
  attempts   Int       @default(0)
  ipPrefix   String?
  createdAt  DateTime  @default(now())

  user User @relation("UserEmailLoginCode", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// Tentative d'inscription via QR code : tracking anti-abus.
// Chaque POST sur /api/programs/[id]/join est loggé ici, qu'il
// réussisse ou non, avec le contexte (IP /24, UA, cookie device,
// fingerprint, email/phone normalisés). Permet le rate limiting
// par dimension et la détection d'abus.
model JoinAttempt {
  id            String     @id @default(cuid())
  programId     String
  ipPrefix      String?    // IP anonymisée (IPv4 /24, IPv6 /48)
  userAgent     String?    @db.Text
  deviceCookie  String?    // valeur du cookie fid_dev (UUID)
  fingerprint   String?    // hash(UA + IP/24 + Accept-Language)
  email         String?    // email normalisé (peut être null)
  phone         String?    // phone normalisé E.164 (peut être null)
  cardId        String?    // si succès, ID de la carte créée
  result        JoinResult
  blockedReason String?    // précision si rate limit / blocage
  createdAt     DateTime   @default(now())

  @@index([programId, createdAt])
  @@index([ipPrefix, createdAt])
  @@index([deviceCookie, createdAt])
  @@index([fingerprint, createdAt])
  @@index([email, createdAt])
  @@index([phone, createdAt])
  @@index([result, createdAt])
}

enum JoinResult {
  SUCCESS
  RATE_LIMITED
  DUPLICATE_RECOVERY  // carte existante → email de récupération envoyé
  PROGRAM_FULL        // limite plan FREE atteinte
  PROGRAM_NOT_FOUND
  VALIDATION_ERROR
}

// Notifications in-app pour le commerçant (cloche dans le header).
// Distinctes des push wallet (qui vont aux clients finaux).
model MerchantNotification {
  id          String                    @id @default(cuid())
  merchantId  String
  type        MerchantNotificationType
  title       String
  body        String?
  link        String?  // URL relative à ouvrir au clic
  readAt      DateTime?
  metadata    Json?    // {cardId, clientId, programId, campaignId, ...}
  createdAt   DateTime @default(now())

  @@index([merchantId, createdAt])
  @@index([merchantId, readAt])
}

enum MerchantNotificationType {
  CLIENT_SIGNUP           // Nouveau client inscrit
  CLIENT_FIRST_REWARD     // 1ère récompense réclamée par un client
  CLIENT_BIRTHDAY_SOON    // Anniversaire d'un client J-7
  CLIENT_BIRTHDAY_TODAY   // Anniversaire d'un client aujourd'hui
  CAMPAIGN_SENT           // Une campagne a été envoyée
  PLAN_LIMIT_WARNING      // Quota plan à 80%
  PLAN_LIMIT_REACHED      // Quota plan à 95% ou 100%
  REFERRAL_SIGNUP         // Un confrère s'est inscrit via ton lien parrainage
  REFERRAL_CONFIRMED      // Filleul a payé sa 1ère facture → crédit appliqué
  SYSTEM                  // Notification générique de Fidlify
}

/// Trace de chaque tentative de connexion (succès + échec).
/// Permet à l'admin de voir l'activité d'un user en cas d'incident.
model LoginLog {
  id        String        @id @default(cuid())
  userId    String?       // null si l'email tapé n'existe pas en DB
  email     String        // tel que tapé par l'utilisateur (normalisé)
  ipPrefix  String?       // IP anonymisée /24 ou /48
  userAgent String?       @db.Text
  result    LoginResult
  reason    String?       // précision (ex: "wrong-password", "suspended", etc.)
  createdAt DateTime      @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([result, createdAt])
}

enum LoginResult {
  SUCCESS
  WRONG_PASSWORD
  USER_NOT_FOUND
  EMAIL_NOT_VERIFIED
  SUSPENDED
  ERROR
}

/// Token de reset password généré par l'admin pour un user.
/// L'admin transmet le lien à l'utilisateur out-of-band (email, SMS, etc.).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique // sha256(token) — token clair jamais stocké
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  createdBy String?   // ID de l'admin qui a généré le token (audit)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

/// Blocage IP géré par l'admin depuis /admin/abuse.
/// Le middleware vérifie chaque requête contre cette table.
model BlockedIp {
  id          String    @id @default(cuid())
  ipPrefix    String    @unique // /24 IPv4 ou /48 IPv6
  reason      String?
  blockedById String?   // ID de l'admin qui a bloqué
  expiresAt   DateTime? // null = blocage permanent
  createdAt   DateTime  @default(now())

  @@index([ipPrefix])
  @@index([expiresAt])
}

// =============================================
// COMMERCANTS (Users)
// =============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  phone         String?
  language      String    @default("fr") // fr, de, it, en
  currency      String    @default("CHF")
  plan               Plan    @default(FREE)
  role               Role    @default(USER)
  employerMerchantId String? // STAFF only: ID of employer merchant
  employerMerchant   User?   @relation("StaffOf", fields: [employerMerchantId], references: [id])
  staff              User[]  @relation("StaffOf")

  stripeCustomerId         String?
  stripeSubscriptionId     String?
  stripePriceId            String?
  stripeCurrentPeriodStart DateTime?
  stripeCurrentPeriodEnd   DateTime?

  // Plan manuel offert par l'admin (partenariat, beta, etc.)
  // Si défini, le plan revient automatiquement à FREE après cette date
  manualPlanUntil  DateTime?
  manualPlanReason String?

  // Onboarding : null = pas encore terminé, redirige vers le wizard.
  // Set quand le commerçant a (1) créé son 1er programme, (2) téléchargé
  // son QR code, (3) validé un scan test.
  onboardingCompletedAt DateTime?

  // Suspension admin : si défini, l'utilisateur ne peut plus se connecter.
  // Différent de la suppression : ses données et programmes sont préservés.
  suspendedAt     DateTime?
  suspendedReason String?
  suspendedById   String?    // ID de l'admin qui a suspendu

  loginLogs           LoginLog[]
  passwordResetTokens PasswordResetToken[]

  // 2FA par email : à chaque login, on envoie un code à 6 chiffres sur
  // l'email du user. Bien plus simple que TOTP (pas d'app à installer)
  // et suffisant pour des comptes ADMIN sur un SaaS lean. Les codes
  // eux-mêmes sont stockés dans EmailLoginCode (hashés + TTL court).
  email2faEnabled  Boolean          @default(false)
  emailLoginCodes  EmailLoginCode[] @relation("UserEmailLoginCode")

  accounts       Account[]
  sessions       Session[]
  establishments Establishment[]
  programs       LoyaltyProgram[]
  campaigns      NotificationCampaign[]

  // Parrainage B2B (merchant → merchant)
  merchantReferralLink        MerchantReferralLink?         @relation("MerchantReferrer")
  merchantReferralAttribution MerchantReferralAttribution?  @relation("MerchantReferee")

  // Audit log (actions effectuées par cet admin sur d'autres ressources)
  adminAuditEntries AdminAuditLog[] @relation("AdminAuditActor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  USER
  STAFF
}

enum Plan {
  FREE
  ESSENTIAL
  GROWTH
  MULTI_SITE
}

// =============================================
// ETABLISSEMENTS
// =============================================

model Establishment {
  id            String  @id @default(cuid())
  merchantId    String
  name          String
  address       String?
  latitude      Float?
  longitude     Float?
  phone         String?
  googlePlaceId String?
  website       String?
  openingHours  Json?   // {"mon": "08:00-18:00", ...}

  merchant     User          @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  programs     LoyaltyProgram[]
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([merchantId])
}

// =============================================
// PROGRAMMES DE FIDELITE
// =============================================

model LoyaltyProgram {
  id              String      @id @default(cuid())
  merchantId      String
  establishmentId String?
  name            String
  type            ProgramType
  isActive        Boolean     @default(true)

  // Config du programme (JSON flexible)
  // stamps:   {"maxStamps": 10, "reward": "1 café offert"}
  // points:   {"pointsPerChf": 1, "tiers": [{"points": 100, "reward": "5 CHF"}, ...]}
  // cashback: {"percentage": 5, "minSpend": 10}
  config Json

  // Design de la carte wallet
  // {"logoUrl": "...", "bgColor": "#1a1a2e", "textColor": "#fff", "stripUrl": "...", "description": "..."}
  cardDesign Json

  // Paramètres Google Review
  googleReviewEnabled    Boolean @default(false)
  googleReviewBonus      Int     @default(0) // tampons/points bonus
  googleReviewMinVisits  Int     @default(3) // nb visites avant de proposer

  merchant      User           @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  establishment Establishment? @relation(fields: [establishmentId], references: [id])
  cards         LoyaltyCard[]
  rewards       Reward[]
  campaigns     NotificationCampaign[]
  referralLinks ReferralLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([merchantId])
}

enum ProgramType {
  STAMPS
  POINTS
  CASHBACK
}

// =============================================
// RECOMPENSES
// =============================================

model Reward {
  id          String     @id @default(cuid())
  programId   String
  name        String
  description String?
  threshold   Int        // nb tampons ou points requis
  rewardType  RewardType
  rewardValue Float?     // montant ou pourcentage
  isActive    Boolean    @default(true)

  program LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  claims  RewardClaim[]

  createdAt DateTime @default(now())
}

enum RewardType {
  FREE_ITEM
  DISCOUNT_CHF
  DISCOUNT_PCT
  CUSTOM
}

// =============================================
// CLIENTS
// =============================================

model Client {
  id            String    @id @default(cuid())
  firstName     String
  email         String?
  phone         String?
  birthDate     DateTime? // Date d'anniversaire (J-M-A) pour campagne anniversaire automatique
  preferredLang String    @default("fr")
  referredById  String?   // client qui l'a parrainé

  referredBy Client?  @relation("Referrals", fields: [referredById], references: [id])
  referrals  Client[] @relation("Referrals")

  cards         LoyaltyCard[]
  referralLinks ReferralLink[]

  createdAt DateTime @default(now())

  @@index([email])
  @@index([phone])
}

// =============================================
// CARTES DE FIDELITE
// =============================================

model LoyaltyCard {
  id             String @id @default(cuid())
  clientId       String
  programId      String
  serialNumber   String @unique // identifiant unique du pass wallet
  currentStamps  Int    @default(0)
  currentPoints  Float  @default(0)
  cashbackBalance Float @default(0)
  /// Tampons gagnés au-delà du seuil pendant un état REWARD_PENDING.
  /// Reportés sur le prochain cycle quand le merchant valide la récompense.
  pendingExtraStamps Int  @default(0)
  /// Points gagnés au-delà du seuil pendant un état REWARD_PENDING (POINTS limité).
  pendingExtraPoints Float @default(0)
  totalVisits    Int    @default(0)
  totalSpent     Float  @default(0)
  status         CardStatus @default(PENDING)
  lastVisitAt    DateTime?
  lastMessage    String?    // dernière notification reçue (campagne) — affichée au verso du pass
  lastMessageAt  DateTime?
  lastCampaignLogo String?  @db.Text // data URL (base64) du logo override pour la dernière campagne
  merchantNotes  String?    @db.Text // notes libres du commerçant sur ce client (drill-down)
  reviewInvitedAt DateTime? // moment où on a invité ce client à laisser un avis Google (anti-spam : 1 seule invitation)

  client        Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  program       LoyaltyProgram     @relation(fields: [programId], references: [id], onDelete: Cascade)
  registrations PassRegistration[]
  transactions  Transaction[]
  rewardClaims  RewardClaim[]
  reviewRequests GoogleReviewRequest[]
  notifications  NotificationLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, programId])
  @@index([programId])
  @@index([status])
}

enum CardStatus {
  PENDING        // Carte créée, mais pas encore validée par un 1er scan en boutique
  ACTIVE
  COMPLETED
  EXPIRED
  REVOKED
  REWARD_PENDING
}

// =============================================
// ENREGISTREMENT DES DEVICES (Push)
// =============================================

model PassRegistration {
  id              String   @id @default(cuid())
  cardId          String
  deviceLibraryId String
  pushToken       String
  platform        Platform

  card LoyaltyCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  registeredAt DateTime @default(now())

  @@unique([cardId, deviceLibraryId])
  @@index([cardId])
}

enum Platform {
  APPLE
  GOOGLE
}

// =============================================
// TRANSACTIONS & HISTORIQUE
// =============================================

model Transaction {
  id              String          @id @default(cuid())
  cardId          String
  establishmentId String?
  type            TransactionType
  value           Float           // nb de tampons/points ajoutés ou retirés
  amountSpent     Float?          // montant de l'achat (optionnel)
  notes           String?

  card          LoyaltyCard    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  establishment Establishment? @relation(fields: [establishmentId], references: [id])

  createdAt DateTime @default(now())

  @@index([cardId])
  @@index([createdAt])
  @@index([type])
}

enum TransactionType {
  STAMP
  POINTS_EARN
  POINTS_SPEND
  REWARD_CLAIM
  CASHBACK_EARN
  CASHBACK_SPEND
  REFERRAL_BONUS
  GOOGLE_REVIEW_BONUS
}

// =============================================
// RECLAMATION RECOMPENSES
// =============================================

model RewardClaim {
  id         String      @id @default(cuid())
  cardId     String
  rewardId   String
  status     ClaimStatus @default(CLAIMED)
  claimedAt  DateTime    @default(now())
  redeemedAt DateTime?

  card   LoyaltyCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  reward Reward      @relation(fields: [rewardId], references: [id])

  @@index([cardId])
}

enum ClaimStatus {
  CLAIMED
  REDEEMED
  EXPIRED
}

// =============================================
// AVIS GOOGLE
// =============================================

model GoogleReviewRequest {
  id          String       @id @default(cuid())
  cardId      String
  bonusStamps Int          @default(0)
  bonusPoints Float        @default(0)
  status      ReviewStatus @default(SENT)
  confirmedAt DateTime?

  card LoyaltyCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  sentAt DateTime @default(now())

  @@index([cardId])
}

enum ReviewStatus {
  SENT       // Le client a cliqué "J'ai laissé un avis" → en attente de validation merchant
  CONFIRMED  // Merchant a vérifié l'avis sur Google + bonus crédité
  REJECTED   // Merchant n'a pas trouvé l'avis → bonus refusé
  EXPIRED    // Demande trop ancienne, jamais traitée
}

// =============================================
// NOTIFICATIONS & CAMPAGNES
// =============================================

model NotificationCampaign {
  id         String      @id @default(cuid())
  merchantId String
  programId  String?
  name       String
  message    String
  triggerType TriggerType
  // scheduled:   {"sendAt": "2026-04-20T17:00:00Z"}
  // geofence:    {"radiusM": 500, "message": "À 2 pas..."}
  // inactivity:  {"daysInactive": 30}
  // postStamp:   {"delayHours": 48}
  // milestone:   {"stampsReached": 5}
  triggerConfig  Json
  targetSegment  Segment @default(ALL)
  status         CampaignStatus @default(DRAFT)
  sentCount      Int     @default(0)
  scheduledAt    DateTime?
  sentAt         DateTime?

  merchant User            @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  program  LoyaltyProgram? @relation(fields: [programId], references: [id])
  logs     NotificationLog[]

  createdAt DateTime @default(now())

  @@index([merchantId])
  @@index([status])
}

enum TriggerType {
  IMMEDIATE
  SCHEDULED
  GEOFENCE
  INACTIVITY
  POST_STAMP
  MILESTONE
  BIRTHDAY    // Auto-déclenché J-7 avant l'anniversaire d'un client
}

enum Segment {
  ALL
  ACTIVE
  DORMANT
  NEW
  VIP
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
  CANCELLED
}

model NotificationLog {
  id          String   @id @default(cuid())
  campaignId  String?
  cardId      String
  delivered   Boolean  @default(false)
  deliveredAt DateTime?

  campaign NotificationCampaign? @relation(fields: [campaignId], references: [id])
  card     LoyaltyCard           @relation(fields: [cardId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([campaignId])
  @@index([cardId])
}

// =============================================
// STRIPE EVENTS (idempotence webhooks)
// =============================================

model StripeEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())
}

// =============================================
// PARRAINAGE
// =============================================

model ReferralLink {
  id            String @id @default(cuid())
  cardId        String?
  clientId      String
  programId     String
  code          String @unique
  uses          Int    @default(0)
  maxUses       Int    @default(10)
  bonusReferrer Int    @default(1)
  bonusReferee  Int    @default(1)

  client  Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  program LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([code])
}

// =============================================
// PARRAINAGE B2B (merchant → merchant)
// =============================================
// Un merchant invite un confrère commerçant. Quand le filleul paie sa
// 1ère facture (+ 14j safety window contre les refunds), les deux reçoivent
// 1 mois gratuit du plan du filleul, cumulable jusqu'à 12 mois pour le parrain.

model MerchantReferralLink {
  id          String  @id @default(cuid())
  merchantId  String  @unique // 1 lien par merchant (auto-créé lazy)
  code        String  @unique // slug ex: "cafe-bellini-r2x9"

  // Tracking funnel
  clicks      Int     @default(0)
  signups     Int     @default(0) // clic → register
  conversions Int     @default(0) // filleul a payé 1ère facture + safety

  // Cap parrain : max 12 mois cumulés offerts
  monthsEarnedTotal Int @default(0)

  merchant      User                          @relation("MerchantReferrer", fields: [merchantId], references: [id], onDelete: Cascade)
  attributions  MerchantReferralAttribution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
}

model MerchantReferralAttribution {
  id          String  @id @default(cuid())
  linkId      String
  refereeId   String  @unique // un filleul ne peut être parrainé qu'1 fois

  status      String  @default("PENDING") // PENDING | CONFIRMED | REVOKED

  // Empreintes anti-fraude posées au moment du register (pas de PII brute)
  refereeIpHash       String?
  refereeFingerprint  String?

  attributedAt DateTime  @default(now()) // moment du register avec le code
  confirmedAt  DateTime?                 // 1ère facture payée + 14j
  revokedAt    DateTime?
  revokedReason String?

  // Plan acheté par le filleul au moment de la confirmation (ESSENTIAL | GROWTH | MULTI_SITE)
  refereePlan            String?
  referrerCreditApplied  Boolean @default(false)
  refereeCreditApplied   Boolean @default(false)

  link    MerchantReferralLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  referee User                 @relation("MerchantReferee", fields: [refereeId], references: [id], onDelete: Cascade)

  @@index([linkId])
  @@index([status])
}

// =============================================
// NEWSLETTER (capture email merchants intéressés)
// =============================================
// Double opt-in obligatoire pour conformité LPD/RGPD :
//  1. Form public → POST /api/newsletter/subscribe → email avec lien confirm
//  2. Click sur le lien → GET /api/newsletter/confirm?token=... → confirmedAt set
// Tant que confirmedAt est null, on NE peut PAS envoyer de newsletter.
//
// Le confirmToken est sha256 d'un secret random (jamais stocké en clair).
// L'unsubscribeToken permet de se désinscrire en 1 clic depuis n'importe
// quel email (pas besoin d'être connecté).

model NewsletterSubscriber {
  id                String    @id @default(cuid())
  email             String    @unique // normalisé (lowercase + trim)
  locale            String    @default("fr") // fr | de | it | en

  // Source de l'inscription (utile pour les stats)
  source            String?   // "footer" | "blog" | "register" | "manual"
  // Référent HTTP au moment de l'inscription (ex: /blog/carte-fidelite-...)
  referer           String?

  // Tokens hashés (sha256 hex)
  confirmTokenHash      String?   // expire après 7 jours si pas confirmé
  confirmTokenExpiresAt DateTime?
  unsubscribeTokenHash  String    // permanent — utilisé pour 1-click unsub

  // Lifecycle
  confirmedAt       DateTime? // null = en attente de double opt-in
  unsubscribedAt    DateTime? // null = encore abonné

  // Anti-abuse
  ipPrefix          String?
  userAgent         String?   @db.Text

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([confirmedAt])
  @@index([unsubscribedAt])
  @@index([createdAt])
}

// =============================================
// AUDIT LOG (actions admin)
// =============================================
// Trace immuable de toute action admin sensible : suspend/unsuspend user,
// reset password, block/unblock IP, modification de plan, etc.
// Obligatoire pour conformité LPD/RGPD ("qui a fait quoi quand").
//
// Pas de FK ON DELETE sur targetId : on accepte que la cible puisse être
// supprimée plus tard, le log reste pour traçabilité.

model AdminAuditLog {
  id         String  @id @default(cuid())
  adminId    String  // ID de l'admin qui a fait l'action
  action     String  // Voir AdminActionType côté code (SUSPEND_USER, BLOCK_IP, ...)

  // Cible de l'action
  targetType String  // "USER" | "IP" | "PROGRAM" | "OTHER"
  targetId   String? // ID Prisma ou IP/prefix selon targetType
  targetLabel String? // Label lisible (email du user, IP, etc.) — utile si la cible est supprimée plus tard

  // Détails libres (oldValue/newValue, reason, etc.)
  metadata   Json?

  // Contexte de la requête admin
  ipPrefix   String?
  userAgent  String? @db.Text

  createdAt  DateTime @default(now())

  admin User @relation("AdminAuditActor", fields: [adminId], references: [id], onDelete: NoAction)

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@index([targetType, targetId])
}
