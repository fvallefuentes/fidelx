      "namedRegex": "^/dashboard/programs/(?<nxtPid>[^/]+?)/customize(?:/)?$"
    },
    {
      "page": "/join/[programId]",
      "regex": "^/join/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPprogramId": "nxtPprogramId"
      },
      "namedRegex": "^/join/(?<nxtPprogramId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/stamp/[serialNumber]",
