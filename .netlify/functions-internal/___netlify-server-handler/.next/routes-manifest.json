      "routeKeys": {
        "nxtPprogramId": "nxtPprogramId"
      },
      "namedRegex": "^/api/programs/(?<nxtPprogramId>[^/]+?)/public(?:/)?$"
    },
    {
      "page": "/api/programs/[programId]/upload-image",
      "regex": "^/api/programs/([^/]+?)/upload\\-image(?:/)?$",
      "routeKeys": {
        "nxtPprogramId": "nxtPprogramId"
      },
      "namedRegex": "^/api/programs/(?<nxtPprogramId>[^/]+?)/upload\\-image(?:/)?$"
    },
    {
      "page": "/api/wallet/apple/[serialNumber]",
      "regex": "^/api/wallet/apple/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPserialNumber": "nxtPserialNumber"
      },
      "namedRegex": "^/api/wallet/apple/(?<nxtPserialNumber>[^/]+?)(?:/)?$"
    },
    {
      "page": "/dashboard/programs/[id]/customize",
