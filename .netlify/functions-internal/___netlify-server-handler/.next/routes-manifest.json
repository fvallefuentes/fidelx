{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/auth/[...nextauth]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPnextauth": "nxtPnextauth"
      },
      "namedRegex": "^/api/auth/(?<nxtPnextauth>.+?)(?:/)?$"
    },
    {
      "page": "/api/blob/[...path]",
      "regex": "^/api/blob/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPpath": "nxtPpath"
      },
      "namedRegex": "^/api/blob/(?<nxtPpath>.+?)(?:/)?$"
    },
    {
      "page": "/api/programs/[programId]",
      "regex": "^/api/programs/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPprogramId": "nxtPprogramId"
      },
      "namedRegex": "^/api/programs/(?<nxtPprogramId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/programs/[programId]/join",
      "regex": "^/api/programs/([^/]+?)/join(?:/)?$",
      "routeKeys": {
        "nxtPprogramId": "nxtPprogramId"
      },
      "namedRegex": "^/api/programs/(?<nxtPprogramId>[^/]+?)/join(?:/)?$"
    },
    {
      "page": "/api/programs/[programId]/public",
